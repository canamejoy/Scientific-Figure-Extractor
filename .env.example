# ─────────────────────────────────────────────────────────────────────────
# AI Scientific Figure Analyzer — environment configuration
# Copy this file to `.env` and adjust as needed.
# ─────────────────────────────────────────────────────────────────────────

# Panel-crop strategy:
#   deterministic  (default) — PDF markers + raster gutter segmentation.
#                              Fast, no model, crops only when confident and
#                              keeps a figure whole otherwise (no garbage).
#   markers-only              — crop only from PDF text markers (most conservative).
#   vlm-assisted              — additionally run the vision grid-audit debate
#                              for hard layouts (montages, touching panels).
#                              Slow; needs a capable model (ideally cloud).
PANEL_CROPPING=deterministic

# ── Vision model — used by the optional analytical chat and the ──────────
# ── vlm-assisted crop mode. Not needed for deterministic extraction. ─────
# Providers: "ollama" (local, no key), "openai", "anthropic".
VLM_PROVIDER=ollama
# Model id. Ollama must be a VISION model (e.g. qwen2.5vl:7b), not a text
# model. OpenAI default gpt-4o; Anthropic default claude-sonnet-5.
VLM_MODEL=qwen2.5vl:7b

# Required for the cloud providers (leave unset for Ollama):
# OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Only if Ollama runs somewhere other than the default local port.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Second auditor for the vlm-assisted debate (optional): two models
# alternate judging each grid and both must sign it off.
# VLM_DEBATE_MODEL=gemma3:12b

# Page-layout detection model (DocLayout-YOLO) is the primary figure
# locator. Set to "off" to force the caption-anchor heuristics instead.
# LAYOUT_DETECTION=on

# Use local layout-model weights instead of downloading from the HF Hub.
# LAYOUT_MODEL_PATH=C:\models\doclayout_yolo_docstructbench_imgsz1024.pt
